#!/usr/bin/env bash
set -e

# Prevent committing env files or obvious secrets
STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
  # block any env.* or .env files from being committed
  if echo "$file" | grep -Eq "(^|/)\.env($|\.|_)|(^|/)env\.|(^|/)\.env.*"; then
    echo "ERROR: Attempt to commit environment file: $file"
    echo "Please remove secrets and add to .env.local (gitignored)."
    exit 1
  fi
  # catch common secret patterns (very basic)
  if git show :"$file" | grep -E "(SUPABASE|SERVICE_ROLE|PRIVATE_KEY|SECRET|PASSWORD)=" -q; then
    echo "ERROR: Potential secret found in $file. Commit aborted."
    exit 1
  fi
done

exit 0